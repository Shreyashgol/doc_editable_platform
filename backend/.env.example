# Copy to backend/.env for local runs. Never commit real secrets.
APP_ENVIRONMENT=local
APP_JWT_SECRET=local-dev-secret-change-me
APP_DATABASE_URL=postgresql+asyncpg://docai:docai@localhost:5432/docai
APP_DATABASE_SYNC_URL=postgresql+psycopg://docai:docai@localhost:5432/docai
APP_REDIS_URL=redis://localhost:6379/0
APP_CELERY_BROKER_URL=redis://localhost:6379/1
APP_CELERY_RESULT_BACKEND=redis://localhost:6379/2
APP_S3_ENDPOINT_URL=http://localhost:9000
APP_S3_ACCESS_KEY=minioadmin
APP_S3_SECRET_KEY=minioadmin
APP_S3_BUCKET=documents
APP_CLAMAV_ENABLED=true
